<?xml version="1.0" encoding="utf-8"?>
<CodeSnippets xmlns="http://schemas.microsoft.com/VisualStudio/2005/CodeSnippet">
    <CodeSnippet Format="1.0.0">
        <Header>
            <Title>Declare Scope Cycle Stat</Title>
			<Shortcut>cyclestat</Shortcut>
        </Header>
        <Snippet>
            <Code Language="C#">
                <![CDATA[using var _ = new IsoScopeCycleStat("$end$");]]>
            </Code>
        </Snippet>
    </CodeSnippet>
</CodeSnippets>